{
  "id": "memory-module-http",
  "activation": {
    "onStartup": true
  },
  "name": "Memory Module HTTP",
  "description": "HTTP adapter plugin for the external OpenClaw-compatible memory-module.",
  "contracts": {
    "tools": [
      "memory_module_retrieve",
      "memory_module_write",
      "memory_module_rag_ingest"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "baseUrl": {
        "type": "string",
        "minLength": 1
      },
      "agentId": {
        "type": "string",
        "minLength": 1
      },
      "retrieveLimit": {
        "type": "integer",
        "minimum": 1
      },
      "autoInject": {
        "type": "boolean"
      },
      "autoCapture": {
        "type": "boolean"
      },
      "captureMaxChars": {
        "type": "integer",
        "minimum": 100
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 250
      }
    }
  }
}
